# Cloudflare Pages _headers
# curative.asia — SEO & AI crawler headers
# Updated: 2026-06-25

# ============================================================
# SITEMAP — must serve as application/xml for Google Search
# ============================================================
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  X-Robots-Tag: noindex
  Cache-Control: public, max-age=3600

# ============================================================
# ROBOTS — plain text, correct content-type
# ============================================================
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

# ============================================================
# LLMs.TXT — plain text for AI agents
# ============================================================
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

# ============================================================
# ALL HTML PAGES — security + AI agent signal headers
# ============================================================
/*.html
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Link: <https://curative.asia/llms.txt>; rel="alternate"; type="text/plain"; title="LLMs.txt"
  Link: <https://curative.asia/sitemap.xml>; rel="sitemap"; type="application/xml"

